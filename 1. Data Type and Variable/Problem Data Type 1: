import java.util.*;
public class Main 
{
  public static void main(String[] args)
  {
    
    Scanner sc = new Scanner(System.in);
    
    float x = sc.nextFloat();
    double y = sc.nextDouble();
    float ProductFloat = x * (float)y;
    double ProductDouble = x * y; 
    
    System.out.printf("Product in float: %.6f\n", ProductFloat);
    System.out.printf("Product in double: %6f\n", ProductDouble);
    
    sc.close();
    
  }
  
}
